#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your-email@gmail.com
#   SMTP_PASS=your-app-specific-password (NOT your Gmail password)
#   SMTP_FROM="ESG Inventory <noreply@yourdomain.com>"
