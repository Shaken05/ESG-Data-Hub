# PostgreSQL connection string (разные команды/субдомены должны использовать разные БД)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/esg_inventory?schema=public
# Порт, на котором backend доступен
PORT=3000
# Окружение: development|production|test
NODE_ENV=development
# JWT secret (обязательно менять в продакшене на уникальное, не хранить в Git)
JWT_SECRET=your-strong-jwt-secret
# Опционально: любой кастомный имя БД для поддомена/команды
DB_NAME=esg_inventory
